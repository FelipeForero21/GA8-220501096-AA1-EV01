# ============================================================
# Variables de Entorno - Metro de Medellín
# Copiar este archivo como .env.local y completar los valores
# ============================================================

# ---- Base de Datos (PostgreSQL) ----
DATABASE_URL="postgresql://usuario:password@localhost:5432/metro_medellin?schema=public"

# ---- NextAuth.js ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"
AUTH_SECRET="generar-con-openssl-rand-base64-32"

# ---- JWT ----
JWT_SECRET="generar-con-openssl-rand-base64-64"
JWT_EXPIRATION="24h"
REFRESH_TOKEN_EXPIRATION="7d"

# ---- Redis (Upstash) ----
UPSTASH_REDIS_REST_URL="https://tu-instancia.upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu-token-de-upstash"

# ---- Pasarela de Pago ----
PAYMENT_API_KEY="pk_test_tu-api-key"
PAYMENT_SECRET_KEY="sk_test_tu-secret-key"
PAYMENT_WEBHOOK_SECRET="whsec_tu-webhook-secret"

# ---- Web Push (VAPID Keys) ----
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="tu-clave-publica-vapid"
VAPID_PRIVATE_KEY="tu-clave-privada-vapid"
VAPID_SUBJECT="mailto:admin@metromedellin.gov.co"

# ---- Aplicación ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Metro de Medellín"
NODE_ENV="development"
